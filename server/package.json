    "@babel/eslint-parser": "^7.28.5",
    "@babel/node": "^7.28.0",
    "@babel/plugin-transform-runtime": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^8.47.0",
    "eslint-formatter-table": "^7.32.1",
    "nodemon": "^3.1.11"
  }
